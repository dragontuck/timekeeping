# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── Database (Tier 3 – host-machine PostgreSQL) ──────────────────────────────
# On Linux/Mac Docker: host.docker.internal resolves to the host
# On Windows Docker Desktop: host.docker.internal is available by default
DATABASE_URL="postgresql://tk_user:CHANGE_ME_DB_PASS@host.docker.internal:5432/timekeeping?schema=public&connection_limit=10&pool_timeout=30"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_GENERATE_RANDOM_64_BYTE_HEX_ACCESS
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_RANDOM_64_BYTE_HEX_REFRESH
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=https://web.timekeeping.local:2443

# ─── Credential Encryption ────────────────────────────────────────────────────
# AES-256 key for encrypting Gmail App Passwords stored in the database.
# Must be exactly 64 hex characters (32 bytes).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIAL_ENCRYPTION_KEY=CHANGE_ME_GENERATE_RANDOM_32_BYTE_HEX

# ─── Cookie ───────────────────────────────────────────────────────────────────
COOKIE_DOMAIN=.timekeeping.local

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5

# ─── Scheduler timezone ───────────────────────────────────────────────────────
TZ=America/New_York
